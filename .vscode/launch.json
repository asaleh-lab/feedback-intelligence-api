{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flask: server.py",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/server.py",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Python: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "cwd": "${fileDirname}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Python: Unit Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "unittest",
      "args": ["-v", "test_sentiment_analysis"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Python: Attach (port 5678)",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "justMyCode": true
    }
  ]
}
