{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Flask server",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": ["server.py"],
      "options": {
        "cwd": "${workspaceFolder}",
        "envFile": "${workspaceFolder}/.env"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "Run unit tests",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": ["-m", "unittest", "-v", "test_sentiment_analysis"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Lint (pylint)",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/pylint.exe",
      "args": [
        "sentiment_analysis",
        "server.py",
        "test_sentiment_analysis.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Type check (basedpyright)",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/basedpyright.exe",
      "args": [],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
